# File Master Configuration

# Required: Bailian/Qwen API Key
# Get from: https://dashscope.console.aliyun.com/apiKey
DASHSCOPE_API_KEY=your_api_key_here

# Optional: Model selection
# Available: qwen-plus, qwen-max, qwen-turbo
DASHSCOPE_MODEL=qwen-plus

# Optional: API base URL (usually don't need to change)
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/api/v1

# Optional: PDF processing limits
PDF_MAX_FILE_SIZE_MB=100
PDF_MAX_PAGES_PER_REQUEST=20
PDF_DEFAULT_MAX_PAGES=50
